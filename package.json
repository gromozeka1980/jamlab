{
  "name": "jamlab",
  "version": "0.1.0",
  "description": "Relational Instruments — a web-based relational improvisation instrument, wrapped for mobile with Capacitor.",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "node scripts/copy-web.mjs",
    "sync": "npm run build:web && cap sync",
    "add:android": "npm run build:web && cap add android",
    "add:ios": "npm run build:web && cap add ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "npm run sync && cap run android",
    "run:ios": "npm run sync && cap run ios",
    "assets": "capacitor-assets generate --android"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^7.1.0",
    "@capacitor-community/media": "^8.0.1",
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.0.0",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/share": "^7.0.4",
    "@capacitor/status-bar": "^7.0.0",
    "@revenuecat/purchases-capacitor": "^11.3.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0"
  }
}
